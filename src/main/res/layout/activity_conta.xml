<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white">

    <View
        android:layout_width="match_parent"
        android:layout_height="6dp"
        android:background="@color/purple_700" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <ImageView
                android:layout_width="180dp"
                android:layout_height="90dp"
                android:layout_gravity="center_horizontal"
                android:adjustViewBounds="true"
                android:scaleType="fitCenter"
                android:src="@drawable/gust_logo" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Minha conta"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/gray_600"
                android:layout_marginTop="10dp" />

            <ImageView
                android:id="@+id/imgFotoPerfil"
                android:layout_width="110dp"
                android:layout_height="110dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_card"
                android:padding="18dp"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_profile"
                android:contentDescription="Foto de perfil" />

            <Button
                android:id="@+id/btnAlterarFoto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_outline_rounded"
                android:text="ALTERAR FOTO"
                android:textColor="@color/white" />

            <EditText
                android:id="@+id/edtNome"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Nome"
                android:layout_marginTop="18dp" />

            <EditText
                android:id="@+id/edtStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Status"
                android:layout_marginTop="10dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tipo de conta"
                android:textStyle="bold"
                android:textColor="@color/gray_600"
                android:layout_marginTop="18dp" />

            <Spinner
                android:id="@+id/spinnerTipoConta"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="6dp" />

            <Button
                android:id="@+id/btnSalvarPerfil"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:background="@drawable/bg_primary_rounded"
                android:text="SALVAR PERFIL"
                android:textColor="@color/white" />

            <Button
                android:id="@+id/btnConfig"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_primary_rounded"
                android:text="CONFIGURAÇÕES"
                android:textColor="@color/white" />

            <Button
                android:id="@+id/btnSair"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_primary_rounded"
                android:text="SAIR"
                android:textColor="@color/white" />

        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/bottomMenu"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="@color/white"
        android:elevation="10dp"
        android:padding="6dp">

        <ImageButton
            android:id="@+id/menuFeed"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:src="@drawable/ic_home"
            android:tint="@color/black"
            android:background="@android:color/transparent" />

        <ImageButton
            android:id="@+id/menuSearch"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:src="@android:drawable/ic_menu_search"
            android:tint="@color/black"
            android:background="@android:color/transparent" />

        <ImageButton
            android:id="@+id/menuChat"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:src="@android:drawable/ic_dialog_email"
            android:tint="@color/black"
            android:background="@android:color/transparent" />

        <ImageButton
            android:id="@+id/menuNotif"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:src="@android:drawable/ic_dialog_info"
            android:tint="@color/black"
            android:background="@android:color/transparent" />

        <ImageButton
            android:id="@+id/menuProfile"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:src="@drawable/ic_profile"
            android:tint="@color/purple_700"
            android:background="@android:color/transparent" />

    </LinearLayout>

</LinearLayout>
