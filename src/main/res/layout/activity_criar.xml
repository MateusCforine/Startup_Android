<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white">

    <View
        android:layout_width="match_parent"
        android:layout_height="6dp"
        android:background="@color/purple_700" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <ImageView
                android:layout_width="180dp"
                android:layout_height="90dp"
                android:layout_gravity="center_horizontal"
                android:adjustViewBounds="true"
                android:scaleType="fitCenter"
                android:src="@drawable/gust_logo" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Criar publicação"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/gray_600"
                android:layout_marginTop="10dp" />

            <EditText
                android:id="@+id/edtDescricao"
                android:layout_width="match_parent"
                android:layout_height="130dp"
                android:layout_marginTop="16dp"
                android:gravity="top"
                android:hint="O que você quer compartilhar?"
                android:padding="12dp" />

            <Button
                android:id="@+id/btnAdicionarImagem"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_outline_rounded"
                android:text="ADICIONAR IMAGEM"
                android:textColor="@color/white" />

            <TextView
                android:id="@+id/txtImagemSelecionada"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Nenhuma imagem selecionada"
                android:textColor="@color/gray_600"
                android:layout_marginTop="8dp" />

            <ImageView
                android:id="@+id/imgPublicacao"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_card"
                android:scaleType="centerCrop"
                android:visibility="gone"
                android:contentDescription="Imagem da publicação" />

            <Button
                android:id="@+id/btnPublicar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_primary_rounded"
                android:text="PUBLICAR"
                android:textColor="@color/white" />

        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/bottomMenu"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="@color/white"
        android:elevation="10dp"
        android:padding="6dp">

        <ImageButton
            android:id="@+id/menuFeed"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:src="@drawable/ic_home"
            android:tint="@color/black"
            android:background="@android:color/transparent" />

        <ImageButton
            android:id="@+id/menuSearch"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:src="@android:drawable/ic_menu_search"
            android:tint="@color/black"
            android:background="@android:color/transparent" />

        <ImageButton
            android:id="@+id/menuChat"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:src="@android:drawable/ic_dialog_email"
            android:tint="@color/black"
            android:background="@android:color/transparent" />

        <ImageButton
            android:id="@+id/menuNotif"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:src="@android:drawable/ic_dialog_info"
            android:tint="@color/black"
            android:background="@android:color/transparent" />

        <ImageButton
            android:id="@+id/menuProfile"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:src="@drawable/ic_profile"
            android:tint="@color/black"
            android:background="@android:color/transparent" />

    </LinearLayout>

</LinearLayout>
